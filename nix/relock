#!/usr/bin/env ruby
# Regenerate Gemfile.lock + gemset.nix for both the main project and the
# ruby-lsp composed bundle in nix/ruby-lsp/.
#
# Use this whenever the main Gemfile changes. Never run plain `bundle install`
# in either tree — gems are materialized by Nix from gemset.nix, not Bundler.

require "fileutils"
require "open3"

ROOT = `git rev-parse --show-toplevel`.strip
abort "not inside a git checkout" if ROOT.empty?
Dir.chdir(ROOT)

BUNDIX = ["nix", "run", "github:inscapist/bundix/main", "--"].freeze
PRUNED_PLATFORMS = %w[
  aarch64-linux-gnu aarch64-linux-musl
  arm-linux-gnu arm-linux-musl
  x86_64-linux-gnu x86_64-linux-musl
].freeze

def sh!(*cmd, chdir: ROOT, allow_fail: false)
  ok = system(*cmd, chdir: chdir)
  return if ok || allow_fail
  raise "command failed: #{cmd.join(" ")}"
end

def strip_checksums(path)
  text = File.read(path)
  File.write(path, text.sub(/\nCHECKSUMS\n(?:[^\n]*\n)*?\n/, "\n"))
end

# Parse a bundix-generated gemset.nix into Hash{name => "  name = { ... };"}.
def parse_gemset(path)
  text = File.read(path)
  blocks = {}
  text.scan(/^  ([\w-]+) = \{.*?^  \};$/m).flatten.zip(
    text.scan(/^  [\w-]+ = \{.*?^  \};$/m)
  ).each { |name, block| blocks[name] = block }
  blocks
end

# Strip the `groups = [...]` and `platforms = [...]` lines for comparison.
# - groups: ruby-lsp-rails being in :development tags every Rails transitive
#   with "development" in the LSP resolution; rubyNix gets no groups filter
#   here, so it doesn't change what loads.
# - platforms: bundix computes per-gem platforms by traversing the dep graph
#   from platform-constrained roots (e.g. debug). The LSP graph reaches stdlib
#   gems through different paths, producing different (but functionally
#   equivalent — host always matches) platform sets.
# Both are bundix bookkeeping, not runtime behavior we depend on.
def normalize(block)
  block
    .sub(/^    groups = \[[^\]]*\];\n/, "")
    .sub(/^    platforms = \[.*?\];\n/m, "")
end

FileUtils.mkdir_p("nix/ruby-lsp")
unless File.exist?("nix/ruby-lsp/Gemfile")
  puts "==> [lsp] seeding nix/ruby-lsp/Gemfile (composed bundle template)"
  File.write("nix/ruby-lsp/Gemfile", <<~GEMFILE)
    # Composed Gemfile for ruby-lsp's bundlerEnv. Project deps come from the main
    # Gemfile via eval_gemfile; only LSP-specific gems are added here.

    eval_gemfile(File.expand_path("../../Gemfile", __dir__))

    gem "ruby-lsp", require: false
    gem "ruby-lsp-rails", require: false
  GEMFILE
end

puts "==> [main] bundle lock"
sh!("bundle", "lock")

# Prune platforms to only the architectures this flake supports
# (x86_64-linux, aarch64-linux). Removing -musl, arm, and per-libc
# variants keeps bundix from downloading .gem files we'll never use.
puts "==> [main] prune lockfile platforms"
sh!("bundle", "lock", "--remove-platform", *PRUNED_PLATFORMS, allow_fail: true)

puts "==> [main] bundix"
sh!(*BUNDIX, "--gemset=nix/gemset.nix")

puts "==> [lsp] mirror project lockfile"
FileUtils.cp("Gemfile.lock", "nix/ruby-lsp/Gemfile.lock")

puts "==> [lsp] bundle lock (resolves ruby-lsp on top of project versions)"
sh!("bundle", "lock", chdir: "#{ROOT}/nix/ruby-lsp")

puts "==> [lsp] prune lockfile platforms"
sh!("bundle", "lock", "--remove-platform", *PRUNED_PLATFORMS,
  chdir: "#{ROOT}/nix/ruby-lsp", allow_fail: true)

puts "==> [lsp] strip CHECKSUMS (bundix can't parse it)"
strip_checksums("nix/ruby-lsp/Gemfile.lock")

# bundle lock in the LSP tree re-stamps the main lockfile's BUNDLED WITH.
# Restore it so the main lockfile is touched only by `bundle lock` in the root.
unless system("git", "diff", "--quiet", "--", "Gemfile.lock")
  shortstat, _ = Open3.capture2("git", "diff", "--shortstat", "--", "Gemfile.lock")
  parts = shortstat.split
  # shortstat: " 1 file changed, 1 insertion(+), 1 deletion(-)"
  inserted = parts[3].to_i
  deleted  = parts[5].to_i
  if inserted + deleted == 2
    puts "==> [main] reverting BUNDLED WITH stamp from LSP relock"
    sh!("git", "checkout", "--", "Gemfile.lock")
  end
end

puts "==> [lsp] bundix (full gemset, will be reduced to additions-only next)"
sh!(*BUNDIX, chdir: "#{ROOT}/nix/ruby-lsp")

puts "==> [lsp] reduce gemset.nix to (import ../gemset.nix) // additions"
main = parse_gemset("nix/gemset.nix")
lsp  = parse_gemset("nix/ruby-lsp/gemset.nix")

additions = lsp.reject { |name, block| main[name] && normalize(main[name]) == normalize(block) }

File.write("nix/ruby-lsp/gemset.nix", <<~NIX)
  # Generated by nix/relock. ruby-lsp composed bundle = main project gems
  # plus the additions below. Identical entries are inherited from
  # ../gemset.nix; only new or version-shifted gems appear here.
  (import ../gemset.nix) // {
  #{additions.values.join("\n")}
  }
NIX

puts "    kept #{additions.size} of #{lsp.size} entries (#{lsp.size - additions.size} inherited from main)"
puts
puts "Done. Run `nix-direnv-reload` (or exit/re-enter the shell) to rebuild rubyEnv."
