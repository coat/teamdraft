# Copy to .env and fill in for local development outside Nix.
# (The Nix flake configures Postgres + env automatically; .env is for the
# devcontainer / non-Nix paths.)

# Postgres connection for `bin/rails server` and `bundle exec rspec`.
DATABASE_URL=postgres://postgres:postgres@localhost:5432/teamdraft_development

# Rails master key (decrypts config/credentials.yml.enc). Already in
# config/master.key on the box that generated the credentials.
# RAILS_MASTER_KEY=

# TheSportsDB key for game/score sync. Free tier: "123".
THESPORTSDB_KEY=123
