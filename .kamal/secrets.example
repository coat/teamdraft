# Copy this file to .kamal/secrets (gitignored) and fill in real values.
# Kamal reads this file at deploy time and injects each variable into the
# container as configured in config/deploy.yml under env.secret.
#
# Lines starting with `#` are comments. Each line is a KEY=VALUE pair, or a
# `KEY=$(command)` invocation that resolves at deploy time.

# Registry credentials. Used to push (from the laptop) and pull (on the
# server). For GHCR these are your GitHub username + a PAT with
# read:/write:packages; for a self-hosted registry they're whatever you
# baked into the htpasswd file.
KAMAL_REGISTRY_USERNAME=your-registry-user
KAMAL_REGISTRY_PASSWORD=your-registry-password

# Rails credentials key - `cat config/master.key` on the machine that owns it.
RAILS_MASTER_KEY=replace-with-contents-of-config-master-key

# Password for the `teamdraft` Postgres role. Used by both the app
# (TEAMDRAFT_DATABASE_PASSWORD) and the bundled Postgres accessory
# (POSTGRES_PASSWORD), which is why both vars resolve to the same value.
TEAMDRAFT_DATABASE_PASSWORD=CHANGEME
POSTGRES_PASSWORD=$TEAMDRAFT_DATABASE_PASSWORD

# TheSportsDB API key. Their free tier accepts "123" but rate-limits aggressively.
# Sign up at https://www.thesportsdb.com/ for a real key.
THESPORTSDB_KEY=123

# Moneyline API key (mlapi.bet) for live odds/scores.
MONEYLINE_API_KEY=CHANGEME
